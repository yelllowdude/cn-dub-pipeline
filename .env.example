ELEVENLABS_API_KEY=
KIE_API_KEY=

# --- Frame.io V4 review integration (all optional) --------------------------
# Only the `review` stage uses these. Leave all blank to run review offline
# from an exported comments file: `review fetch --comments-json ...`.
#
# PREFERRED — OAuth Server-to-Server (the pipeline mints/refreshes its own
# access tokens). Create an Adobe Developer Console project, add the Frame.io
# API, add an "OAuth Server-to-Server" credential, and copy its id/secret here.
# (Requires a Frame.io V4 account administered via the Adobe Admin Console.)
FRAMEIO_CLIENT_ID=
FRAMEIO_CLIENT_SECRET=
#
# FALLBACK — a static V4 access token pasted directly. Simplest, but expires
# (~24h) and must be re-pasted. NOTE: a legacy V2 "fio-u-..." token will NOT
# work against the V4 API. Leave blank if using client id/secret above.
FRAMEIO_TOKEN=
