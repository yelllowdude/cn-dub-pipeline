ELEVENLABS_API_KEY=
KIE_API_KEY=

# --- Frame.io V4 review integration (all optional) --------------------------
# Only the `review` stage uses these. Leave all blank to run review offline
# from an exported comments file: `review fetch --comments-json ...`.
#
# Adobe Developer Console credential (id + secret). Works two ways:
#   - User Authentication (Web App): after setting these, run
#       cn-pipeline review auth
#     once to sign in via the browser -- it stores FRAMEIO_REFRESH_TOKEN below
#     and the pipeline then refreshes access tokens on its own. Use this if
#     Server-to-Server is greyed out ("License required") in the console.
#   - Server-to-Server: id + secret alone (needs an Adobe Admin Console license).
FRAMEIO_CLIENT_ID=
FRAMEIO_CLIENT_SECRET=
#
# Written automatically by `cn-pipeline review auth` -- normally leave blank.
FRAMEIO_REFRESH_TOKEN=
#
# FALLBACK — a static V4 access token pasted directly. Simplest, but expires
# (~24h) and must be re-pasted. NOTE: a legacy V2 "fio-u-..." token will NOT
# work against the V4 API. Leave blank if using the credential above.
FRAMEIO_TOKEN=

# --- YouTube publish, Chinese channel (all optional) ------------------------
# Only `cn-pipeline publish youtube` uses these. Desktop OAuth client from
# Google Cloud Console (YouTube Data API v3 enabled). Then run
#   cn-pipeline publish auth
# once, signing in AS the channel account (yellowdude.zh@gmail.com) — it
# stores YOUTUBE_REFRESH_TOKEN below and uploads run unattended after that.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Written automatically by `cn-pipeline publish auth` — normally leave blank.
YOUTUBE_REFRESH_TOKEN=
