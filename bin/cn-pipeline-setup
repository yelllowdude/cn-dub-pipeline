#!/bin/bash
# One-time per-machine setup: venv + starter .env/config.json.
# Lives in CLAUDE_PLUGIN_DATA (not CLAUDE_PLUGIN_ROOT) so it survives plugin
# updates -- an update re-syncs the plugin's tracked files, not this.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="${CLAUDE_PLUGIN_ROOT:-$(dirname "$SCRIPT_DIR")}"
DATA="${CLAUDE_PLUGIN_DATA:-$ROOT}"
VENV="$DATA/venv"

mkdir -p "$DATA"

if [ -x "$VENV/bin/python" ]; then
  echo "venv already exists at $VENV -- reinstalling requirements."
  "$VENV/bin/pip" install -q -r "$ROOT/requirements.txt"
else
  # Prefer 3.14 (the version the team pins and tests against), but any
  # reasonably current python3 works -- don't make a teammate's setup fail
  # over a minor-version mismatch.
  PY=""
  for v in 3.14 3.13 3.12; do
    if command -v "python$v" >/dev/null 2>&1; then PY="python$v"; break; fi
  done
  if [ -z "$PY" ]; then
    echo "No python3.12+ found. Install one first (macOS: brew install python@3.14)." >&2
    exit 1
  fi
  if [ "$PY" != "python3.14" ]; then
    echo "NOTE: python3.14 not found; using $PY. The team pins 3.14 -- if pip install"
    echo "fails on a dependency below, install python@3.14 and rerun."
  fi
  echo "Creating venv at $VENV (using $PY) ..."
  "$PY" -m venv "$VENV"
  "$VENV/bin/pip" install -q -r "$ROOT/requirements.txt"
fi
echo "Python environment ready."

if [ ! -f "$DATA/.env" ]; then
  cp "$ROOT/.env.example" "$DATA/.env"
  echo "Created $DATA/.env -- fill in ELEVENLABS_API_KEY and KIE_API_KEY (shared team keys, in the team password vault -- see README 'Credentials')."
else
  echo "$DATA/.env already exists, left as-is."
fi

if [ ! -f "$DATA/config.json" ]; then
  cp "$ROOT/config.example.json" "$DATA/config.json"
  echo "Created $DATA/config.json -- gdrive storage mode is preset; run 'cn-pipeline drive auth' once (see README)."
else
  echo "$DATA/config.json already exists, left as-is."
fi

echo
echo "Next: edit $DATA/.env and $DATA/config.json, then confirm with:"
echo "  cn-pipeline preflight --project-id <a-real-project-id>"
